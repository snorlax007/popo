# Popo Cloud Backend — environment variables
# Copy to .env and fill in values before starting the server.

# App
APP_NAME=Popo Cloud
APP_TAGLINE=The backend that gives your desk a soul.
PORT=8000
SECRET_KEY=change-me-to-a-random-64-char-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Database (PostgreSQL for production, SQLite for dev)
DATABASE_URL=postgresql+asyncpg://popo:popo@localhost:5432/popo
# For local dev without Docker: sqlite+aiosqlite:///./popo.db

# Redis
REDIS_URL=redis://localhost:6379/0
WEATHER_CACHE_TTL=600

# Anthropic (Claude Haiku for mood classification)
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeatherMap
OWM_API_KEY=your-owm-key-here

# S3 / Cloudflare R2 (OTA firmware storage)
S3_BUCKET=popo-firmware
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
OTA_URL_EXPIRY=3600

# MQTT (Mosquitto)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Sentry (optional)
SENTRY_DSN=
